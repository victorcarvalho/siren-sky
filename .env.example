# Path to the dataset directory containing images for classification
DATASET_PATH=dataset

# OpenAI API key for authentication with the GPT API
OPENAI_API_KEY=your_api_key_here

# The prompt template used to classify images via the API
CLASSIFICATION_PROMPT=Is there garbage in this image? Answer with yes or no.

# Image detail level for API calls (low, high, or auto)
IMAGE_DETAIL=auto

# OpenAI model to use for image classification
MODEL=gpt-4.1-nano

# Whether to use simulated predictions instead of calling the actual API
USE_SIMULATED_PREDICTIONS=true

# MLflow tracking server URI for experiment tracking and logging
TRACKING_URI=http://127.0.0.1:5000
